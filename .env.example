# Server Configuration
NODE_ENV=development
PORT=3000

# Database - Full connection string
DATABASE_URL=postgresql://your-username:your-password@your-host.us-east-1.aws.neon.tech/project_env?sslmode=require

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Use * for mobile apps
CORS_ORIGIN=*

# Super Admin - LOCAL ONLY
SUPER_ADMIN_EMAIL=admin@local.com
SUPER_ADMIN_PASSWORD=changeme
