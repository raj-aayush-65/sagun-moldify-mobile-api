# Server Configuration
NODE_ENV=development
PORT=3000

# Database - Full connection string
DATABASE_URL=postgresql://your-username:your-password@your-host.us-east-1.aws.neon.tech/project_env?sslmode=require

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed Token - Used to create first Super Admin
SEED_TOKEN=your_seed_token_here

# Encryption Secret - REQUIRED for password encryption
# Generate a secure random string (min 32 characters recommended)
ENCRYPTION_SECRET=your-encryption-secret-min-32-chars
