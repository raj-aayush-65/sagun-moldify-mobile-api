# Beta Environment Configuration
NODE_ENV=beta
PORT=3000

# Database - Full NeonDB connection string
DATABASE_URL=postgresql://your-username:your-password@your-host.us-east-1.aws.neon.tech/project_env?sslmode=require

# JWT
JWT_SECRET=beta_jwt_secret_change_this_beta
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Allow all for mobile apps
CORS_ORIGIN=*