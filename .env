# Local Development Environment
NODE_ENV=development
PORT=3000

# Database - NeonDB connection string
DATABASE_URL=postgresql://your-username:your-password@your-host.us-east-1.aws.neon.tech/project_env?sslmode=require

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed Token - Used to create first Super Admin
SEED_TOKEN=dev_seed_token_change_this